int i, j, max_idx, temp;

    for (i = 0; i < n - 1; i++)
    {
        max_idx = i;

        for (j = i + 1; j < n; j++)
        {
            if (arr[j] > arr[max_idx])
            {
                max_idx = j;
            }
        }

        if (max_idx != i)
        {
            temp = arr[i];
            arr[i] = arr[max_idx];
            arr[max_idx] = temp;
        }
	}
